// Prisma Schema - 大模型安全护栏检测平台
// 数据库: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. 模型供应商配置表
// ============================================
model LlmProvider {
  id                  String   @id @default(uuid())
  name                String   @unique // 'deepseek', 'kimi', 'doubao'
  displayName         String   @map("display_name")
  providerType        String   @map("provider_type") // 'openai_compatible', 'coze', 'ollama', 'custom'
  baseUrl             String?  @map("base_url")
  apiKeyEncrypted     String?  @map("api_key_encrypted")
  defaultModel        String?  @map("default_model")
  useCase             String?  @map("use_case") // 'target', 'judge', 'both'
  isEnabled           Boolean  @default(true) @map("is_enabled")
  isDefaultTarget     Boolean  @default(false) @map("is_default_target")
  isDefaultJudge      Boolean  @default(false) @map("is_default_judge")
  avgLatencyMs        Int?     @map("avg_latency_ms")
  lastTestAt          DateTime? @map("last_test_at")
  lastTestSuccess     Boolean? @map("last_test_success")
  configJson          Json?    @map("config_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  createdBy           String   @default("system") @map("created_by")

  // Relations
  sessionsAsTarget   DetectionSession[] @relation("TargetProvider")
  sessionsAsJudge    DetectionSession[] @relation("JudgeProvider")
  agentTraces        AgentTrace[]

  @@map("llm_providers")
}

// ============================================
// 2. 检测会话表
// ============================================
model DetectionSession {
  id                  String   @id @default(uuid())
  userId              String?  @map("user_id") // 用户ID，支持多用户
  userPrompt          String   @map("user_prompt")
  
  // 模型配置
  targetProviderId    String?  @map("target_provider_id")
  targetModel         String?  @map("target_model")
  judgeProviderId     String?  @map("judge_provider_id")
  judgeModel          String?  @map("judge_model")
  
  // 输入护栏结果
  inputAction         String?  @map("input_action")
  inputScore          Decimal? @map("input_score") @db.Decimal(5, 2)
  inputSummary        String?  @map("input_summary")
  inputFindings       Json?    @map("input_findings")
  
  // 模拟大模型输出
  mockModelOutput     String?  @map("mock_model_output")
  modelCallSuccess    Boolean? @map("model_call_success")
  modelLatencyMs      Int?     @map("model_latency_ms")
  
  // 输出护栏结果
  outputAction        String?  @map("output_action")
  outputScore         Decimal? @map("output_score") @db.Decimal(5, 2)
  outputSummary       String?  @map("output_summary")
  outputFindings      Json?    @map("output_findings")
  
  // 最终决策
  finalAction         String?  @map("final_action")
  finalResponse       String?  @map("final_response")
  
  // 策略引用
  policyId            String?  @map("policy_id")
  
  // 元数据
  createdAt           DateTime @default(now()) @map("created_at")
  totalDurationMs     Int?     @map("total_duration_ms")
  clientIp            String?  @map("client_ip")
  userAgent           String?  @map("user_agent")

  // Relations
  targetProvider      LlmProvider?   @relation("TargetProvider", fields: [targetProviderId], references: [id])
  judgeProvider       LlmProvider?   @relation("JudgeProvider", fields: [judgeProviderId], references: [id])
  policy              PolicyProfile? @relation(fields: [policyId], references: [id])
  records             DetectionRecord[]
  evaluationResults   EvaluationResult[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([finalAction])
  @@index([policyId])
  @@index([targetProviderId])
  @@map("detection_sessions")
}

// ============================================
// 3. 检测记录表
// ============================================
model DetectionRecord {
  id                  String   @id @default(uuid())
  sessionId           String   @map("session_id")
  direction           String   // 'input', 'output'
  
  // 文本内容
  rawText             String   @map("raw_text")
  maskedText          String?  @map("masked_text")
  rewrittenText       String?  @map("rewritten_text")
  
  // 评分结果
  overallScore        Decimal? @map("overall_score") @db.Decimal(5, 2)
  confidence          Decimal? @db.Decimal(3, 2)
  
  // 处理动作
  action              String?
  summary             String?
  
  // 检测来源
  detectionSource     String?  @map("detection_source") // 'rule', 'llm', 'hybrid'
  
  // 性能指标
  ruleLatencyMs       Int?     @map("rule_latency_ms")
  llmLatencyMs        Int?     @map("llm_latency_ms")
  totalLatencyMs      Int?     @map("total_latency_ms")
  
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  session             DetectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  findings            RiskFinding[]
  agentTraces         AgentTrace[]

  @@index([sessionId])
  @@index([direction])
  @@index([action])
  @@map("detection_records")
}

// ============================================
// 4. 风险明细表 ⭐ 核心表
// ============================================
model RiskFinding {
  id                  String   @id @default(uuid())
  recordId            String   @map("record_id")
  
  // 风险维度
  dimension           String   // 'prompt_injection', 'pii_leak', 'malicious_code', 'violence_hate', 'illegal_content'
  
  // 评分详情
  score               Decimal? @db.Decimal(5, 2)
  confidence          Decimal? @db.Decimal(3, 2)
  severity            String?  // 'critical', 'high', 'medium', 'low'
  
  // 命中规则
  matchedRules        Json?    @map("matched_rules")
  evidence            Json?
  
  // 检测来源
  detectionSource     String?  @map("detection_source") // 'rule', 'llm', 'both'
  
  // 解释说明
  reason              String?
  suggestion          String?
  
  // LLM判断详情
  llmProviderId       String?  @map("llm_provider_id")
  llmRawResponse      Json?    @map("llm_raw_response")
  
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  record              DetectionRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  llmProvider         LlmProvider?    @relation(fields: [llmProviderId], references: [id])

  @@index([recordId])
  @@index([dimension])
  @@index([severity])
  @@index([detectionSource])
  @@map("risk_findings")
}

// ============================================
// 5. 策略方案表
// ============================================
model PolicyProfile {
  id                        String   @id @default(uuid())
  name                      String   @unique
  description               String?
  
  // 版本管理
  version                   Int      @default(1)
  isDefault                 Boolean  @default(false) @map("is_default")
  isActive                  Boolean  @default(true) @map("is_active")
  
  // 默认模型配置
  defaultTargetProviderId   String?  @map("default_target_provider_id")
  defaultJudgeProviderId    String?  @map("default_judge_provider_id")
  
  // 元数据
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  createdBy                 String   @default("system") @map("created_by")

  // Relations
  sessions                  DetectionSession[]
  rules                     PolicyRule[]
  keywords                  KeywordRule[]
  evaluationRunsA           EvaluationRun[] @relation("PolicyA")
  evaluationRunsB           EvaluationRun[] @relation("PolicyB")

  @@map("policy_profiles")
}

// ============================================
// 6. 策略规则表
// ============================================
model PolicyRule {
  id                  String   @id @default(uuid())
  policyId            String   @map("policy_id")
  
  // 规则配置
  dimension           String
  enabled             Boolean  @default(true)
  
  // 阈值设置
  warnThreshold       Decimal  @default(50.0) @map("warn_threshold") @db.Decimal(5, 2)
  blockThreshold      Decimal  @default(80.0) @map("block_threshold") @db.Decimal(5, 2)
  
  // 动作配置
  autoMask            Boolean  @default(false) @map("auto_mask")
  autoRewrite         Boolean  @default(false) @map("auto_rewrite")
  enableLlmJudge      Boolean  @default(true) @map("enable_llm_judge")
  
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  policy              PolicyProfile @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([dimension])
  @@map("policy_rules")
}

// ============================================
// 7. 自定义关键词规则表
// ============================================
model KeywordRule {
  id                  String   @id @default(uuid())
  policyId            String   @map("policy_id")
  
  // 关键词配置
  dimension           String
  keyword             String
  score               Decimal  @default(90.0) @db.Decimal(5, 2)
  enabled             Boolean  @default(true)
  caseSensitive       Boolean  @default(false) @map("case_sensitive")
  
  // 元数据
  description         String?
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  policy              PolicyProfile @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([dimension])
  @@map("keyword_rules")
}

// ============================================
// 8. 测试用例表
// ============================================
model TestCase {
  id                  String   @id @default(uuid())
  
  // 基本信息
  title               String
  description         String?
  category            String   // 'normal_qa', 'prompt_injection', 'pii_leak', 'malicious_code', 'violence_hate', 'illegal_content', 'output_leak'
  
  // 测试内容
  inputText           String   @map("input_text")
  outputText          String?  @map("output_text")
  
  // 期望结果
  expectedAction      String?  @map("expected_action")
  expectedDimensions  Json?    @map("expected_dimensions")
  expectedScoreMin    Decimal? @map("expected_score_min") @db.Decimal(5, 2)
  expectedScoreMax    Decimal? @map("expected_score_max") @db.Decimal(5, 2)
  
  // 元数据
  severity            String?  // 'critical', 'high', 'medium', 'low'
  enabled             Boolean  @default(true)
  tags                Json?
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  evaluationResults   EvaluationResult[]

  @@index([category])
  @@index([enabled])
  @@map("test_cases")
}

// ============================================
// 9. 批量评估任务表
// ============================================
model EvaluationRun {
  id                  String   @id @default(uuid())
  userId              String?  @map("user_id") // 用户ID，支持多用户
  
  // 任务信息
  name                String
  description         String?
  
  // 配置
  testCaseIds         String[] @map("test_case_ids")
  policyAId           String?  @map("policy_a_id")
  policyBId           String?  @map("policy_b_id")
  targetProviderId    String?  @map("target_provider_id")
  judgeProviderId     String?  @map("judge_provider_id")
  
  // 状态
  status              String   @default("pending") // 'pending', 'running', 'completed', 'failed'
  progress            Int      @default(0)
  
  // 统计结果
  totalCases          Int      @default(0) @map("total_cases")
  passedCases         Int      @default(0) @map("passed_cases")
  failedCases         Int      @default(0) @map("failed_cases")
  
  // A策略结果
  policyAAccuracy     Decimal? @map("policy_a_accuracy") @db.Decimal(5, 2)
  policyAPrecision    Decimal? @map("policy_a_precision") @db.Decimal(5, 2)
  policyARecall       Decimal? @map("policy_a_recall") @db.Decimal(5, 2)
  policyAF1Score      Decimal? @map("policy_a_f1_score") @db.Decimal(5, 2)
  
  // B策略结果
  policyBAccuracy     Decimal? @map("policy_b_accuracy") @db.Decimal(5, 2)
  policyBPrecision    Decimal? @map("policy_b_precision") @db.Decimal(5, 2)
  policyBRecall       Decimal? @map("policy_b_recall") @db.Decimal(5, 2)
  policyBF1Score      Decimal? @map("policy_b_f1_score") @db.Decimal(5, 2)
  
  // 差异样例
  differenceExamples  Json?    @map("difference_examples")
  
  // 元数据
  createdAt           DateTime @default(now()) @map("created_at")
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  createdBy           String?  @map("created_by")

  // Relations
  policyA             PolicyProfile? @relation("PolicyA", fields: [policyAId], references: [id])
  policyB             PolicyProfile? @relation("PolicyB", fields: [policyBId], references: [id])
  results             EvaluationResult[]

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("evaluation_runs")
}

// ============================================
// 10. 评估结果详情表
// ============================================
model EvaluationResult {
  id                  String   @id @default(uuid())
  runId               String   @map("run_id")
  testCaseId          String   @map("test_case_id")
  
  // 检测结果
  sessionId           String?  @map("session_id")
  
  // 实际结果
  actualAction        String?  @map("actual_action")
  actualScore         Decimal? @map("actual_score") @db.Decimal(5, 2)
  actualDimensions    Json?    @map("actual_dimensions")
  
  // 评估结果
  isCorrect           Boolean? @map("is_correct")
  isFalsePositive     Boolean? @map("is_false_positive")
  isFalseNegative     Boolean? @map("is_false_negative")
  errorReason         String?  @map("error_reason")
  
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  run                 EvaluationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase            TestCase @relation(fields: [testCaseId], references: [id])
  session             DetectionSession? @relation(fields: [sessionId], references: [id])

  @@index([runId])
  @@index([isCorrect])
  @@map("evaluation_results")
}

// ============================================
// 11. Agent运行日志表
// ============================================
model AgentTrace {
  id                  String   @id @default(uuid())
  recordId            String   @map("record_id")
  
  // Agent信息
  agentName           String   @map("agent_name") // 'RiskClassifier', 'JudgeAgent'
  agentType           String   @map("agent_type") // 'rule', 'llm', 'hybrid'
  
  // 输入输出
  inputPayload        Json?    @map("input_payload")
  outputPayload       Json?    @map("output_payload")
  
  // 性能指标
  latencyMs           Int?     @map("latency_ms")
  
  // 状态
  success             Boolean  @default(true)
  errorMessage        String?  @map("error_message")
  
  // 提供商信息
  providerId          String?  @map("provider_id")
  modelName           String?  @map("model_name")
  
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  record              DetectionRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  provider            LlmProvider? @relation(fields: [providerId], references: [id])

  @@index([recordId])
  @@index([agentName])
  @@index([providerId])
  @@map("agent_traces")
}

// ============================================
// 12. 用户设置表
// ============================================
model UserSettings {
  id                        String   @id @default(uuid())
  userId                    String   @unique @map("user_id")
  
  // 默认配置
  defaultTargetProviderId   String?  @map("default_target_provider_id")
  defaultJudgeProviderId    String?  @map("default_judge_provider_id")
  defaultPolicyId           String?  @map("default_policy_id")
  
  // 功能开关
  enableLlmJudge            Boolean  @default(true) @map("enable_llm_judge")
  enableRuleDetection       Boolean  @default(true) @map("enable_rule_detection")
  enableAutoMask            Boolean  @default(true) @map("enable_auto_mask")
  enableSafeRewrite         Boolean  @default(false) @map("enable_safe_rewrite")
  
  // 偏好设置
  preferredLanguage         String   @default("zh-CN") @map("preferred_language")
  theme                     String   @default("light")
  
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

// ============================================
// 13. 系统设置表
// ============================================
model SystemSettings {
  id                        String   @id @default(uuid())
  
  // 默认模型配置
  defaultTargetProviderId   String?  @map("default_target_provider_id")
  defaultJudgeProviderId    String?  @map("default_judge_provider_id")
  defaultPolicyId           String?  @map("default_policy_id")
  
  // 全局开关
  enableLlmJudge            Boolean  @default(true) @map("enable_llm_judge")
  enableRuleDetection       Boolean  @default(true) @map("enable_rule_detection")
  enableAutoMask            Boolean  @default(true) @map("enable_auto_mask")
  enableSafeRewrite         Boolean  @default(false) @map("enable_safe_rewrite")
  
  // 性能配置
  detectionTimeoutMs        Int      @default(30000) @map("detection_timeout_ms")
  maxInputLength            Int      @default(10000) @map("max_input_length")
  maxOutputLength           Int      @default(10000) @map("max_output_length")
  
  // 日志配置
  logRetentionDays         Int      @default(90) @map("log_retention_days")
  enableAuditLog           Boolean  @default(true) @map("enable_audit_log")
  
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================
// 14. 导出任务表
// ============================================
model ExportJob {
  id                  String   @id @default(uuid())
  
  // 任务信息
  type                String   // 'records', 'evaluation', 'ab_comparison', 'model_eval'
  format              String   // 'json', 'csv', 'markdown'
  
  // 筛选条件
  filters             Json?    // 筛选条件的JSON表示
  
  // 状态
  status              String   @default("pending") // 'pending', 'processing', 'completed', 'failed'
  progress            Int      @default(0)
  
  // 结果
  fileUrl             String?  @map("file_url")
  fileSize            Int?     @map("file_size")
  recordCount         Int?     @map("record_count")
  
  // 错误信息
  errorMessage        String?  @map("error_message")
  
  // 元数据
  createdBy           String?  @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")
  completedAt         DateTime? @map("completed_at")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("export_jobs")
}

// ============================================
// 15. 审计日志表
// ============================================
model AuditLog {
  id                  String   @id @default(uuid())
  
  // 操作信息
  userId              String?  @map("user_id")
  action              String   // 'create', 'update', 'delete', 'export', 'login'
  resource            String   // 'provider', 'policy', 'session', 'test_case'
  resourceId          String?  @map("resource_id")
  
  // 详细信息
  details             Json?    // 操作详情
  
  // 客户端信息
  ipAddress           String?  @map("ip_address")
  userAgent           String?  @map("user_agent")
  
  // 结果
  success             Boolean  @default(true)
  errorMessage        String?  @map("error_message")
  
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
