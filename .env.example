# GuardLLM 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接 URL
DATABASE_URL=postgres://guardllm:guardllm_secret_2024@localhost:5432/guardllm

# 数据库用户名（Docker Compose 使用）
DB_USER=guardllm

# 数据库密码（Docker Compose 使用，生产环境请修改）
DB_PASSWORD=guardllm_secret_2024

# 数据库名称
DB_NAME=guardllm

# 数据库端口（Docker Compose 使用）
DB_PORT=5432

# ==================== 应用配置 ====================
# 应用端口
PORT=5000
APP_PORT=5000

# 运行环境
NODE_ENV=production

# ==================== LLM API 配置 ====================
# LLM API 密钥（支持 OpenAI、DeepSeek 等）
LLM_API_KEY=your-api-key-here

# LLM API 基础 URL（可选，用于自定义端点）
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# LLM 模型名称
LLM_MODEL_NAME=gpt-4o-mini

# ==================== 安全配置 ====================
# 加密密钥（用于敏感数据加密，请使用随机字符串）
ENCRYPTION_KEY=your-random-encryption-key-change-in-production

# ==================== 可选配置 ====================
# 日志级别
LOG_LEVEL=info

# 是否启用调试模式
DEBUG=false
